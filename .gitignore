# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# Environment
.env
.env.local

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Data — large datasets are linked, not committed
data/*.csv
data/*.parquet
data/*.xlsx
data/raw/
!data/README.md

# Backups and editor noise
*.bak
*.swp
*~

# Pipeline-generated artifacts that DO go into git as demo evidence:
#   data/*.manifest.yaml — versionable manifest from /snapshot-data
#   quality_report_*.md  — output from /quality-report
#   reports/figures/*.png — figures referenced from the EDA report
#   notebooks/*.ipynb     — the demo notebook executed end-to-end

# Backups / experiments
*_backup*
*_test*
*_unknown_origin*

# Corporate templates — never publish
**/reference.docx
**/templates/reference.docx

# Generated DOCX inherits corporate styles — keep markdown only as the public artifact
reports/*.docx
